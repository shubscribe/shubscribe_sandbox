# ---- Database (Turso) ----
# Local dev: leave both unset to use a local SQLite file (file:local.db).
# Production: create a DB at https://turso.tech, then:
#   turso db show <name> --url        → TURSO_DATABASE_URL
#   turso db tokens create <name>     → TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- Auth ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: https://<your-domain>/api/auth/callback/google
# (and http://localhost:3000/api/auth/callback/google for local dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist — only these Google accounts can sign in.
ALLOWED_EMAILS=lokhandeshubham701@gmail.com

# If Google creds are unset, a passwordless "dev mode" login is shown.
# It is disabled in production unless you explicitly set:
# ALLOW_DEV_LOGIN=true

# ---- v2: protects the /api/scan cron endpoint ----
# Any random string; Vercel sends it automatically on cron invocations.
CRON_SECRET=
